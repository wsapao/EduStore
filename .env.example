# ──────────────────────────────────────────────────────────────────────────────
# LOJA VIRTUAL ESCOLAR — Variáveis de Ambiente
# Copie este arquivo para .env.local (dev) ou configure no painel do Vercel (prod)
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui   # apenas server-side

# ── URL pública da loja ───────────────────────────────────────────────────────
# Usada em links de email, QR Code de ingressos e callbacks de webhook
NEXT_PUBLIC_SITE_URL=https://www.seudominio.com.br

# ── Escola ────────────────────────────────────────────────────────────────────
# Aparece no login, cadastro, título da aba e manifest PWA
NEXT_PUBLIC_ESCOLA_NOME=Colégio Inovação
# Cor primária em HEX — define o tema visual de toda a loja
NEXT_PUBLIC_ESCOLA_COR=#1a2f5a

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtenha sua chave em https://resend.com/api-keys
# Sem esta variável os emails são ignorados silenciosamente (a loja funciona normalmente)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Remetente — o domínio deve estar verificado no Resend
EMAIL_FROM=Loja Escolar <noreply@seudominio.com.br>

# ── Gateway de Pagamento — Asaas ──────────────────────────────────────────────
# Crie sua conta em https://www.asaas.com
# Em NODE_ENV=production, a aplicação RECUSA iniciar sem esta chave
# (a menos que PAGAMENTOS_PERMITIR_MOCK=1 seja explicitamente definido).
ASAAS_API_KEY=$aact_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 'sandbox' para testes | 'production' para cobranças reais
ASAAS_ENVIRONMENT=sandbox
# Token para validar webhooks enviados pelo Asaas
ASAAS_WEBHOOK_TOKEN=um_segredo_forte_gerado_por_voce
# Flag de emergência para rodar com mock em produção — use apenas em staging!
# PAGAMENTOS_PERMITIR_MOCK=1

# ── Cron — Expiração automática de PIX ───────────────────────────────────────
# Segredo para proteger o endpoint /api/cron/expire-pix
# Gere com: openssl rand -hex 32
CRON_SECRET=um_segredo_forte_gerado_por_voce

# ── Rate limiting (Upstash Redis) — opcional mas recomendado em produção ─────
# Sem estas variáveis o rate limit roda em memória (reset a cada cold start).
# Crie em https://console.upstash.com → Redis → "REST" credentials.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry — observabilidade de erros ────────────────────────────────────────
# Crie um projeto em https://sentry.io (plano gratuito disponível).
# Sem DSN o Sentry é desativado silenciosamente em build e runtime.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=sua-org
SENTRY_PROJECT=loja-escolar
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxx

# Observabilidade (PostHog - Opcional para Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── QA exploratório (staging) ─────────────────────────────────────────────────
# URL do preview/staging que o agente de QA vai testar (NUNCA produção).
QA_BASE_URL=https://edu-store-staging.vercel.app
# Domínio de staging custom permitido pela trava de segurança (além de *.vercel.app).
QA_STAGING_HOST=
# Domínio da caixa de teste para e-mails gerados pelo QA.
QA_TEST_EMAIL_DOMAIN=qa.test
